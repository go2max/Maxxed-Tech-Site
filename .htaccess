# Hostinger deploys this repository at public_html. Keep the generated
# static site in site/ while serving it as the public document root.
RewriteEngine On

# Prevent rewrite loops after an internal route into site/.
RewriteRule ^site(?:/|$) - [L]

# Serve the homepage at the domain root.
RewriteRule ^$ site/index.html [L]

# Map only generated public files and directories into the site output.
RewriteCond %{DOCUMENT_ROOT}/site/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/site/$1 -d
RewriteRule ^(.+)$ site/$1 [L]

# Do not expose repository source, documentation, or configuration files.
ErrorDocument 404 /site/404.html
RewriteRule ^ - [R=404,L]
