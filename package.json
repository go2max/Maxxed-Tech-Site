{
  "name": "maxxed-technical-systems-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check:public": "node ./scripts/build.mjs && node ./scripts/validate-site.mjs && node ./scripts/validate-artifact.mjs",
    "check:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/check.ps1",
    "check": "node ./scripts/check.mjs",
    "validate": "node scripts/validate-site.mjs && node scripts/validate-artifact.mjs",
    "platform:check": "node ./scripts/check-platform.mjs",
    "runner:check": "node ./scripts/check-runner.mjs",
    "admin:seed": "node admin/src/seed-admin-data.mjs",
    "admin:build": "node admin/src/build-admin.mjs",
    "admin:test": "node admin/tests/admin.test.mjs",
    "admin:check": "node admin/src/seed-admin-data.mjs && node admin/src/build-admin.mjs && node admin/tests/admin.test.mjs",
    "check:admin-boundary": "node scripts/validate-admin-boundary.mjs"
  }
}
