# Copy this file to the deployed admin directory as `.htaccess` only after creating
# the referenced .htpasswd file outside the public web root.
#
# Do not commit the real .htpasswd file.
# Do not leave the placeholder AuthUserFile path below.

AuthType Basic
AuthName "TechMaxxed Admin"
AuthUserFile /absolute/non-public/path/to/.htpasswd
Require valid-user

<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow, noarchive"
  Header set Cache-Control "no-store"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "no-referrer"
</IfModule>

Options -Indexes
