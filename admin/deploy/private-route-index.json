{
  "scope": "private_admin_routes",
  "accessRequired": true,
  "routes": [
    {
      "id": "admin_dashboard",
      "type": "static_admin_app",
      "source": "dist-admin/index.html",
      "public": false,
      "notes": "Primary private admin dashboard after build."
    },
    {
      "id": "seed_report_page",
      "type": "static_admin_page",
      "source": "admin/report/index.html",
      "public": false,
      "notes": "Read-only seed readiness page."
    },
    {
      "id": "seed_report_json",
      "type": "worker_get_route",
      "source": "admin/api/report-worker.mjs",
      "public": false,
      "notes": "Read-only seed readiness JSON endpoint."
    },
    {
      "id": "commerce_health",
      "type": "worker_get_route",
      "source": "admin/api/commerce-worker.mjs",
      "public": false,
      "notes": "Private commerce scaffold health endpoint."
    }
  ],
  "publicExposureAllowed": false
}
