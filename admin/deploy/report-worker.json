{
  "name": "maxxed-admin-report-worker",
  "entrypoint": "admin/api/report-worker.mjs",
  "route": "admin.techmaxxed.com/api/report/*",
  "staticPage": "admin/report/index.html",
  "staticPath": "/admin/report/",
  "access": {
    "required": true,
    "provider": "Cloudflare Access or equivalent admin gate",
    "notes": "Keep the worker route and static report page private. Do not expose this route on the public site."
  },
  "behavior": {
    "readOnly": true,
    "databaseWrites": false,
    "publicNavigation": false,
    "checkoutEnabled": false
  },
  "checks": [
    "node admin/tests/report-worker.test.mjs",
    "node admin/tests/admin-report-page.test.mjs",
    "node admin/tests/seed-report.test.mjs"
  ]
}
